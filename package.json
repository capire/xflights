{
  "name": "@capire/xflights",
  "version": "0.1.3",
  "description": "CAP sample for master data service",
  "scripts": {
    "start": "cds watch --port 4005",
    "reset": "cds deploy && cds watch --port 4005"
  },
  "dependencies": {
    "@sap/cds": ">=9"
  },
  "devDependencies": {
    "@cap-js/sqlite": ">=2"
  },
  "cds": {
    "requires": {
      "messaging": true
    },
    "log": {
      "levels": {
        "hcql": "error",
        "cds": "debug"
      }
    }
  },
  "license": "Apache-2.0"
}
